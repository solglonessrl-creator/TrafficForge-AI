# CONFIGURACIÓN TRAFFICFORGE AI 24/7

# 1. Supabase (Base de Datos & Auth)
# Obtener en Supabase Dashboard > Settings > API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-anon-key-aqui

# URL de Landing (para CTA y conversiones)
LANDING_PAGE_URL=https://librodeautoayuda.netlify.app

# 2. OpenAI (IA Principal)
# Obtener en platform.openai.com > API Keys
OPENAI_API_KEY=sk-tu-openai-key-aqui

# 3. Groq (IA Alternativa - Llama3)
# Obtener en console.groq.com > API Keys
GROQ_API_KEY=gsk_tu-groq-key-aqui

# 4. Google Gemini (IA Económica/Gratis)
# Obtener en aistudio.google.com
GEMINI_API_KEY=tu-gemini-key-aqui

# 5. Stripe (Pagos - Opcional por ahora)
# Obtener en Stripe Dashboard > Developers > API Keys (Test Mode)
STRIPE_API_KEY=sk_test_tu-key-aqui
STRIPE_WEBHOOK_SECRET=whsec_tu-secret-aqui

# 5. Email (Opcional)
# Obtener en SendGrid o similar
SENDGRID_API_KEY=tu-sendgrid-key-aqui

# Configuración de Automatización
HEADLESS_BROWSER=True
HUMAN_DELAY_MIN=1.5
HUMAN_DELAY_MAX=4.0
